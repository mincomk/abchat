# Deployment Configuration
HTTP_PORT=80

# Database
POSTGRES_USER=abchat
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=abchat

# Backend
JWT_SECRET=replace_with_secure_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH= # Generate this by running 'cargo run --bin hash' in the backend/ directory (Use single quotes!)
VAPID_PUBLIC_KEY=replace_with_your_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_your_vapid_private_key

# Bot
DISCORD_TOKEN=your_discord_token
DISCORD_CHANNEL_ID=your_discord_channel_id
ABCHAT_CHANNEL_ID=your_abchat_channel_id
LOG_LEVEL=info
NODE_ENV=production

# Frontend (Publicly exposed)
# Note: When using the Nginx setup, API and WS base URLs should end in /api
VITE_WS_BACKEND_URL=ws://localhost/api
VITE_API_BASE_URL=http://localhost/api

